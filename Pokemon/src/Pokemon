Class Pokemon {
    private String nom;
    private int pvMax;
    private int attaque;
    private int defense;
    private int vitesse;
    private Type type1;
    private Type type2;
    private static final int NB_ATTAQUES = 4;
    private Attaque[NB_ATTAQUES] attaque;
    private static final int CONST_ATTAQUE = 20;
    private int = CONST_ATTAQUE;
    private static final int CONST_DEFENSE = 50;
    private int = CONST_DEFENSE;
    

    public Pokemon (String nom) { 
       this.nom = nom;
       this.pvMax = pvMax;
       this.attaque = attaque;
       this.defense = defense;
       this.vitesse = vitesse;
       this.type1 = type1
       this.type2 = type2
    }

    public Attaque getAttaqueByIndex(int index){
        return attaques[index];
    }

    public void attaquer(Attaque attaque, Pokemon adversaire){
        int cm=1;

        cm = attaque.getType().calculCM(adversaire.getType1(), adversaire.getType2());
        


        int dommagesAttaque =  (20 * this.attaque * attaque.puissance);
        int degatsAvantCM = dommagesAttaque / adversaire.defense / 50;
        int degatsFinaux = degatsAvantCM * cm;
    }

    public Type getType1(){
        return this.type1;
    }

    public Type getType2(){
        return this.type2;
    }
}